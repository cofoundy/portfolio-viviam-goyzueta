---
import { siteConfig } from "../config";
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- AI-generated gradient background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/hero-bg.png"
      alt=""
      class="w-full h-full object-cover opacity-60"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg)]/40 via-transparent to-[var(--bg)]"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
    <div class="hero-name">
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight leading-tight drop-shadow-lg">
        {siteConfig.name}
      </h1>
      <p class="text-3xl sm:text-4xl md:text-6xl font-bold mt-1 bg-gradient-to-r from-[var(--magentra)] via-[var(--solara)] to-[var(--aqva)] bg-clip-text text-transparent drop-shadow-lg">
        {siteConfig.lastName}
      </p>
    </div>

    <div class="hero-tagline mt-8">
      <div class="inline-flex items-center gap-3 text-white text-sm sm:text-base font-mono bg-[var(--bg)]/60 backdrop-blur-sm px-5 py-2 rounded-full">
        <span class="text-[var(--aqva)]">&gt;</span>
        <span id="identity-text" class="inline-block min-w-[140px]">{siteConfig.identities[0]}</span>
        <span class="w-0.5 h-5 bg-[var(--magentra)] animate-pulse"></span>
      </div>
    </div>

    <p class="hero-tagline mt-6 text-white/80 text-sm sm:text-base max-w-lg mx-auto leading-relaxed drop-shadow-md">
      {siteConfig.profile.summary.slice(0, 160)}...
    </p>

    <div class="hero-tagline mt-8 flex items-center justify-center gap-4">
      <a
        href="#work"
        class="px-6 py-2.5 bg-[var(--magentra)] text-white text-sm font-medium rounded-full hover:shadow-lg hover:shadow-[var(--magentra)]/30 transition-all"
      >
        Ver proyectos
      </a>
      <a
        href="#contact"
        class="px-6 py-2.5 bg-white/10 backdrop-blur-sm border border-white/30 text-white text-sm font-medium rounded-full hover:bg-white/20 transition-all"
      >
        Contacto
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll absolute bottom-8 left-1/2 -translate-x-1/2">
    <div class="w-5 h-8 border-2 border-white/30 rounded-full flex justify-center">
      <div class="w-1 h-2 bg-[var(--magentra)] rounded-full mt-1.5 animate-bounce"></div>
    </div>
  </div>
</section>

<script>
  const identities = ["UX Engineer", "Web Designer", "Founder", "Legal Mind", "Researcher"];
  const el = document.getElementById('identity-text');
  let index = 0;

  if (el) {
    setInterval(() => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(-10px)';
      setTimeout(() => {
        index = (index + 1) % identities.length;
        el.textContent = identities[index];
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, 200);
    }, 2500);

    el.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
  }
</script>
